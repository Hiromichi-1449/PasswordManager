<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bottom_sheet_background"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/generatedPassword"
        android:text="Your password"
        android:textSize="20sp"
        android:textStyle="bold"
        android:paddingBottom="16dp"
        android:textColor="@color/black"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Length"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="8dp"/>

        <EditText
            android:id="@+id/inputLength"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="12"
            android:textColor="@color/black"
            android:gravity="center"
            android:maxLength="2"
            android:background="@android:drawable/editbox_background"
            android:layout_marginEnd="16dp"/>

        <ImageButton
            android:id="@+id/btnCopy"
            android:src="@drawable/ic_copy"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Copy password"
            android:layout_gravity="center_vertical"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="numbers"
            android:textColor="@color/black"
            android:layout_marginEnd="8dp"/>

        <Switch
            android:id="@+id/switchNumbers"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="signs"
            android:textColor="@color/black"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"/>

        <Switch
            android:id="@+id/switchSymbols"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="upper case"
            android:textColor="@color/black"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"/>

        <Switch
            android:id="@+id/switchUppercase"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnGenerate"
        android:text="Generate New"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:layout_marginTop="16dp"
        android:backgroundTint="#000000"/>
</LinearLayout>
